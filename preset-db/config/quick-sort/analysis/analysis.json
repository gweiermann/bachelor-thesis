{
    "entrypointFunction": "quickSort",
    "collect": [
        {
            "type": "arrayWatcher",
            "parameters": {
                "name": "arr",
                "size": "n"
            },
            "key": "array"
        },
        {
            "type": "currentLine",
            "key": "line"
        },
        {
            "type": "currentScope",
            "key": "scope"
        },
        {
            "type": "recursionWatcher",
            "key": "recursion"
        },
        {
            "type": "arrayCompareOperationWatcher",
            "parameters": {
                "name": "arr",
                "size": "n"
            },
            "key": "arrayComparisons"
        }
    ]
}